{
  "name": "ollamapilot",
  "displayName": "OllamaPilot (MCP Edition)",
  "version": "0.4.0-alpha",
  "description": "Your offline AI co-pilot powered by Ollama with MCP support — 100% local, no telemetry, no internet required",
  "publisher": "dtenney",
  "author": {
    "name": "David Tenney",
    "url": "https://github.com/dtenney"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kchikech/Ollama_Agent"
  },
  "bugs": {
    "url": "https://github.com/kchikech/Ollama_Agent/issues"
  },
  "homepage": "https://github.com/kchikech/Ollama_Agent#readme",
  "sponsor": {
    "url": "https://github.com/sponsors/kchikech"
  },
  "keywords": [
    "ollama",
    "ai",
    "llm",
    "offline",
    "coding-assistant",
    "agent",
    "local-ai"
  ],
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "icon": "images/logo.png",
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "vendor": "node scripts/vendor-hljs.js",
    "build": "npm run vendor && tsc",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "highlight.js": "^11.11.1",
    "typescript": "^5.0.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ollama-sidebar",
          "title": "Ollama Agent",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "ollama-sidebar": [
        {
          "type": "webview",
          "id": "ollamaAgent.chatView",
          "name": "Chat"
        },
        {
          "id": "ollamaAgent.memoryView",
          "name": "Memory"
        }
      ]
    },
    "commands": [
      {
        "command": "ollamaAgent.newChat",
        "title": "New Chat",
        "icon": "$(add)"
      },
      {
        "command": "ollamaAgent.openChat",
        "title": "Ollama: Open Chat"
      },
      {
        "command": "ollamaAgent.generateCode",
        "title": "Ollama: Generate Code (selection)"
      },
      {
        "command": "ollamaAgent.explainSelection",
        "title": "Ollama: Explain Selection"
      },
      {
        "command": "ollamaAgent.codeAction",
        "title": "Ollama: Code Action"
      },
      {
        "command": "ollamaAgent.explainError",
        "title": "Ollama: Explain Error"
      },
      {
        "command": "ollamaAgent.diagnose",
        "title": "Ollama: Run Diagnostics"
      },
      {
        "command": "ollamaAgent.createMCPConfig",
        "title": "Ollama: Create MCP Config File"
      },
      {
        "command": "ollamaAgent.runMemoryMaintenance",
        "title": "Ollama: Run Memory Maintenance"
      },
      {
        "command": "ollamaAgent.refreshMemory",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ollamaAgent.promoteEntry",
        "title": "Promote to Higher Tier",
        "icon": "$(arrow-up)"
      },
      {
        "command": "ollamaAgent.demoteEntry",
        "title": "Demote to Lower Tier",
        "icon": "$(arrow-down)"
      },
      {
        "command": "ollamaAgent.deleteMemoryEntry",
        "title": "Delete Entry",
        "icon": "$(trash)"
      },
      {
        "command": "ollamaAgent.exportMemory",
        "title": "Ollama: Export Memory"
      },
      {
        "command": "ollamaAgent.importMemory",
        "title": "Ollama: Import Memory"
      },
      {
        "command": "ollamaAgent.showMemoryStats",
        "title": "Ollama: Show Memory Statistics",
        "icon": "$(graph)"
      },
      {
        "command": "ollamaAgent.manageTemplates",
        "title": "Ollama: Manage Prompt Templates"
      },
      {
        "command": "ollamaAgent.triggerInlineCompletion",
        "title": "Ollama: Trigger Inline Completion"
      },
      {
        "command": "ollamaAgent.exportChatMarkdown",
        "title": "Ollama: Export Chat as Markdown"
      },
      {
        "command": "ollamaAgent.exportChatJSON",
        "title": "Ollama: Export Chat as JSON"
      },
      {
        "command": "ollamaAgent.switchWorkspace",
        "title": "Ollama: Switch Workspace Folder"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ollamaAgent.newChat",
          "when": "view == ollamaAgent.chatView",
          "group": "navigation"
        },
        {
          "command": "ollamaAgent.refreshMemory",
          "when": "view == ollamaAgent.memoryView",
          "group": "navigation@1"
        },
        {
          "command": "ollamaAgent.showMemoryStats",
          "when": "view == ollamaAgent.memoryView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ollamaAgent.promoteEntry",
          "when": "view == ollamaAgent.memoryView && viewItem == memoryEntry",
          "group": "inline@1"
        },
        {
          "command": "ollamaAgent.demoteEntry",
          "when": "view == ollamaAgent.memoryView && viewItem == memoryEntry",
          "group": "inline@2"
        },
        {
          "command": "ollamaAgent.deleteMemoryEntry",
          "when": "view == ollamaAgent.memoryView && viewItem == memoryEntry",
          "group": "inline@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ollamaAgent.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      },
      {
        "command": "ollamaAgent.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "ollamaAgent.acceptDiff",
        "key": "alt+a",
        "mac": "alt+a",
        "when": "diffEditorVisible"
      },
      {
        "command": "ollamaAgent.rejectDiff",
        "key": "alt+r",
        "mac": "alt+r",
        "when": "diffEditorVisible"
      },
      {
        "command": "ollamaAgent.triggerInlineCompletion",
        "key": "alt+c",
        "mac": "alt+c",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Ollama Agent",
      "properties": {
        "ollamaAgent.baseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Full base URL for the Ollama server, e.g. `http://localhost:11434`. When set, overrides `host` + `port`."
        },
        "ollamaAgent.host": {
          "type": "string",
          "default": "localhost",
          "description": "Ollama server hostname (used only when baseUrl is empty)."
        },
        "ollamaAgent.port": {
          "type": "number",
          "default": 11434,
          "description": "Ollama server port (used only when baseUrl is empty)."
        },
        "ollamaAgent.model": {
          "type": "string",
          "default": "llama2",
          "description": "Default model to use when the extension starts. Overridable per session via the model selector in the sidebar."
        },
        "ollamaAgent.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "markdownDescription": "Sampling temperature (0 = deterministic, 1 = balanced, 2 = creative). Only sent to Ollama when it differs from the default."
        },
        "ollamaAgent.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt override. Leave empty to use the built-in coding assistant prompt."
        },
        "ollamaAgent.autoIncludeFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-attach the full active file content to every message sent."
        },
        "ollamaAgent.autoIncludeSelection": {
          "type": "boolean",
          "default": true,
          "description": "Auto-attach selected code from the active editor when a selection exists."
        },
        "ollamaAgent.maxContextFiles": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of workspace files to include when the agent auto-loads context. Higher values increase token usage."
        },
        "ollamaAgent.injectGitDiff": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When enabled, injects a concise `git diff` of your uncommitted changes into every message. Helps the agent understand what you're currently working on. Only works in git repositories."
        },
        "ollamaAgent.mcpServers": {
          "type": "array",
          "default": [],
          "markdownDescription": "MCP (Model Context Protocol) servers to connect to. Each server provides additional tools for the agent. Example: `[{\"name\": \"filesystem\", \"command\": \"npx\", \"args\": [\"-y\", \"@modelcontextprotocol/server-filesystem\", \"/path/to/workspace\"]}]`",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Server name"
              },
              "command": {
                "type": "string",
                "description": "Command to run"
              },
              "args": {
                "type": "array",
                "description": "Command arguments",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "description": "Environment variables"
              }
            },
            "required": [
              "name",
              "command",
              "args"
            ]
          }
        },
        "ollamaAgent.memory.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable multi-tiered memory system for persistent project knowledge."
        },
        "ollamaAgent.memory.qdrantUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Qdrant server URL for semantic search (e.g., `http://localhost:6333`). Leave empty to automatically use Ollama host with port 6333."
        },
        "ollamaAgent.memory.qdrantHost": {
          "type": "string",
          "default": "",
          "description": "Qdrant hostname. Leave empty to use Ollama host."
        },
        "ollamaAgent.memory.qdrantPort": {
          "type": "number",
          "default": 6333,
          "description": "Qdrant port (default: 6333)."
        },
        "ollamaAgent.memory.embeddingModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Ollama embedding model for semantic search (e.g., nomic-embed-text, mxbai-embed-large)."
        },
        "ollamaAgent.memory.embeddingUrl": {
          "type": "string",
          "default": "",
          "description": "Ollama URL for embeddings. Leave empty to use main Ollama URL."
        },
        "ollamaAgent.memory.autoLoadTiers": {
          "type": "array",
          "default": [
            0,
            1,
            2
          ],
          "description": "Memory tiers to auto-load on session start (0=critical, 1=essential, 2=operational).",
          "items": {
            "type": "number"
          }
        },
        "ollamaAgent.memory.demotionThresholdDays": {
          "type": "number",
          "default": 30,
          "description": "Days before demoting stale memories to lower tier."
        },
        "ollamaAgent.memory.promotionAccessCount": {
          "type": "number",
          "default": 5,
          "description": "Number of accesses before promoting memory to higher tier."
        },
        "ollamaAgent.memory.archiveThresholdDays": {
          "type": "number",
          "default": 90,
          "description": "Days before archiving old memories to Tier 5."
        },
        "ollamaAgent.memory.maxContextTokens": {
          "type": "number",
          "default": 4000,
          "description": "Maximum tokens for memory context in prompts."
        },
        "ollamaAgent.memory.semanticSearchLimit": {
          "type": "number",
          "default": 5,
          "description": "Default number of results for semantic search queries."
        },
        "ollamaAgent.memory.fallbackToLocal": {
          "type": "boolean",
          "default": true,
          "description": "Fall back to local storage if Qdrant is unavailable."
        },
        "ollamaAgent.memory.autoSave": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically save important information to memory as the AI discovers it (IPs, frameworks, tasks, solutions). The AI will proactively store context without being asked."
        },
        "ollamaAgent.autoCompactContext": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically compact conversation history when context reaches 99% of model's limit. You'll be alerted at 70% usage and reminded until 99%, then auto-compact will trigger if enabled."
        },
        "ollamaAgent.inlineCompletions.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable inline code completions (similar to GitHub Copilot). Suggestions appear automatically as you type. **Note:** This feature uses your local Ollama model and may slow down typing on slower machines."
        },
        "ollamaAgent.inlineCompletions.triggerMode": {
          "type": "string",
          "enum": ["automatic", "manual"],
          "default": "automatic",
          "markdownDescription": "How to trigger inline completions: `automatic` (as you type) or `manual` (only when you press the shortcut)."
        },
        "ollamaAgent.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "markdownDescription": "Milliseconds to wait after typing stops before generating a completion. Higher values reduce API calls but increase latency."
        }
      }
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6"
  }
}
