# ── Everything bundled into dist/main.js — exclude the rest ───────────────────

# Source & build tooling
src/**
**/*.ts
tsconfig.json
esbuild.js
.vscode/**
.github/**
scripts/**

# ALL node_modules (bundled by esbuild)
node_modules/**

# Individual tsc output (only dist/main.js is needed)
dist/**
!dist/main.js

# Dev docs
IMPLEMENTATION_PLAN.md
SESSION_FINAL_STATE.md
SESSION_STATE.md
CHANGELOG.md
CONTRIBUTING.md
CONTEXT_MANAGEMENT_TODO.md
PYTHON_TOOLING_TODO.md
SYNERGY_AUDIT.md
NEXT_FEATURES.md
GAP_ANALYSIS.md
MANUAL_TESTS.md
MEMORY_IMPROVEMENTS.md
.ollamapilot/**

# Build artefacts
*.vsix
package-lock.json
.nycrc
coverage/**
.nyc_output/**
.vscode-test.mjs
.vscode-test/**

# Git
.gitignore
.git/**

# Logs / temp
*.log
*.tsbuildinfo
vsce_ls.txt

# OS artefacts
.DS_Store
Thumbs.db

# ── Keep in VSIX ─────────────────────────────────────────────────────────────
# dist/main.js     ← single bundled extension file
# webview/**        ← chat UI (HTML + JS + vendor hljs)
# images/**         ← logo, banner, sidebar icon, demo gif
# package.json      ← manifest
# README.md         ← Marketplace description
# LICENSE
