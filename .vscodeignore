# ── Source (compiled to dist/) ────────────────────────────────────────────────
src/**
**/*.ts
!dist/**

# ── Dev tooling ───────────────────────────────────────────────────────────────
# Include all production dependencies (MCP SDK + transitive deps)
# Exclude only devDependencies
node_modules/@types/**
node_modules/@vscode/**
node_modules/@azure/**
node_modules/@typespec/**
node_modules/typescript/**
node_modules/highlight.js/**
tsconfig.json
.vscode/**
.github/**
scripts/**

# ── Git ───────────────────────────────────────────────────────────────────────
.gitignore
.git/**

# ── Logs / temp ───────────────────────────────────────────────────────────────
*.log
*.tsbuildinfo
coverage/**
.nyc_output/**

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Keep these in the VSIX ────────────────────────────────────────────────────
# dist/**        ← included (compiled extension)
# webview/**     ← included (chat UI)
# images/**      ← included (sidebar icon)
# package.json   ← included (manifest)
# README.md      ← included (Marketplace description)
# CONTRIBUTING.md← included
# LICENSE        ← included
