# ── Source & build tooling (never ship) ──────────────────────────────────────
src/**
**/*.ts
tsconfig.json
esbuild.js
.vscode/**
.github/**
scripts/**

# node_modules — exclude most, but keep runtime third-party deps
# (axios, @modelcontextprotocol/sdk are required at runtime by dist/ files)
node_modules/**
!node_modules/axios/**
!node_modules/axios-retry/**
!node_modules/follow-redirects/**
!node_modules/form-data/**
!node_modules/combined-stream/**
!node_modules/delayed-stream/**
!node_modules/mime-types/**
!node_modules/mime-db/**
!node_modules/proxy-from-env/**
!node_modules/@modelcontextprotocol/**
!node_modules/zod/**
!node_modules/zod-to-json-schema/**
!node_modules/eventsource-parser/**
!node_modules/content-type/**
!node_modules/is-stream/**
!node_modules/cross-spawn/**
!node_modules/shebang-command/**
!node_modules/shebang-regex/**
!node_modules/which/**
!node_modules/path-key/**
!node_modules/ajv/**
!node_modules/ajv-formats/**
!node_modules/fast-deep-equal/**
!node_modules/fast-uri/**
!node_modules/json-schema-traverse/**
!node_modules/require-from-string/**
!node_modules/eventsource/**
!node_modules/json-schema-typed/**
!node_modules/jose/**
!node_modules/pkce-challenge/**

# dist/ — include ALL tsc-compiled files (tsc produces one file per module)
# (previously only dist/main.js was needed when esbuild produced a single bundle)

# Dev docs
IMPLEMENTATION_PLAN.md
SESSION_FINAL_STATE.md
SESSION_STATE.md
CHANGELOG.md
CONTRIBUTING.md
CONTEXT_MANAGEMENT_TODO.md
PYTHON_TOOLING_TODO.md
SYNERGY_AUDIT.md
NEXT_FEATURES.md
GAP_ANALYSIS.md
MANUAL_TESTS.md
MEMORY_IMPROVEMENTS.md
.ollamapilot/**
DESIGN_VISION.md
PROJECT_STATUS.md

# Build artefacts
*.vsix
package-lock.json
.nycrc
coverage/**
.nyc_output/**
.vscode-test.mjs
.vscode-test/**

# Git
.gitignore
.git/**

# Logs / temp
*.log
*.tsbuildinfo
vsce_ls.txt

# OS artefacts
.DS_Store
Thumbs.db

# ── Keep in VSIX ─────────────────────────────────────────────────────────────
# dist/**           ← tsc-compiled extension files
# webview/**        ← chat UI (HTML + JS + vendor hljs)
# images/**         ← logo, banner, sidebar icon, demo gif
# package.json      ← manifest
# README.md         ← Marketplace description
# LICENSE
