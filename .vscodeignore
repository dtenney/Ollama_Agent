# Build artefacts
*.vsix
package-lock.json
.nycrc
coverage/**
.nyc_output/**
.vscode-test.mjs
.vscode-test/**

# Git
.gitignore
.git/**
.claude/**

# Logs / temp
*.log
*.tsbuildinfo
vsce_ls.txt

# OS artefacts
.DS_Store
Thumbs.db

# ── Keep in VSIX ─────────────────────────────────────────────────────────────
# dist/**           ← tsc-compiled extension files
# webview/**        ← chat UI (HTML + JS + vendor hljs)
# images/**         ← logo, banner, sidebar icon, demo gif
# docs/CHANGELOG.md ← user-facing release notes
# package.json      ← manifest
# README.md         ← Marketplace description
# settings.example.json
# mcp.example.json
# LICENSE
